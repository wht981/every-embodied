# Option A: OpenAI-compatible provider
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=
VLM_MODEL=qwen-vl-plus

# Option B: Gemini via OpenAI-compatible endpoint
# GEMINI_API_KEY=your_gemini_key
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GEMINI_MODEL=gemini-3-flash

# OpenClaw web + inventory integration
OPENCLAW_WEB_HOST=127.0.0.1
OPENCLAW_WEB_PORT=8000
OPENCLAW_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Feishu notification for low-stock alerts
OPENCLAW_FEISHU_APP_ID=
OPENCLAW_FEISHU_APP_SECRET=
OPENCLAW_FEISHU_NOTIFY_TARGET=
OPENCLAW_FEISHU_NOTIFY_RECEIVE_ID_TYPE=chat_id
OPENCLAW_FEISHU_NOTIFY_ENABLED=1

# Optional collaboration webhook for your own robot backend
OPENCLAW_ROBOT_WEBHOOK_URL=
