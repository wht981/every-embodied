<mujoco model="scene">

    <include file="../universal_robots_ur5e/ur5e.xml" />
    <include file="../robotiq_2f85/2f85.xml" />

    <compiler angle="radian" autolimits="true" />
	
    <option timestep="0.002" integrator="implicitfast" solver="PGS" gravity="0 0 -9.82" cone="elliptic">
		
    </option>

	
    <statistic center="1.8 1.1 1.7" extent="0.8" meansize="0.08" />

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0" />
        <rgba haze="0.15 0.25 0.35 1" />

		
		<global azimuth="210" elevation="-35" offheight="1280" offwidth="1280" />
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072" />
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300" />
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2" />

        
        <mesh name="table" file="../table/sigmund_table.stl" scale="1 1 1" />
		<mesh name="Apple" file="../fruit/Apple.STL" scale="0.001 0.001 0.001" />
		<mesh name="Banana" file="../fruit/Banana.STL" scale="0.001 0.001 0.001" />

		<mesh name="hammer_head" file="../hammer/hammer_head.stl" />
		<mesh name="hammer_neck" file="../hammer/hammer_neck.stl" />
		<mesh name="hammer_contact0" file="../hammer/contact0.stl" />
		<mesh name="hammer_contact1" file="../hammer/contact1.stl" />

		<mesh name="knife_blade" file="../knife/knife_blade.stl" />
        <mesh name="knife_handle" file="../knife/knife_handle.stl" />
        <mesh name="knife_contact0" file="../knife/contact0.stl" />
        <mesh name="knife_contact1" file="../knife/contact1.stl" />

		<mesh name="duck" file="../duck/duck.stl" scale="0.8 0.8 0.8" />
        <mesh name="duck_contact0" file="../duck/contact0.stl" scale="0.8 0.8 0.8" />
        <mesh name="duck_contact1" file="../duck/contact1.stl" scale="0.8 0.8 0.8" />
        <mesh name="duck_contact2" file="../duck/contact2.stl" scale="0.8 0.8 0.8" />
        <mesh name="basket_mesh" file="../libero_basket/visual/basket_vis.msh" scale="1 1 1" />

		

		<texture name="apple_tex" type="2d" file="../fruit/mesh/red-apple.png" />
		<material name="apple_mat" texture="apple_tex" />
		<texture name="banana_tex" type="2d" file="../fruit/mesh/yellow-banana.png" />
		<material name="banana_mat" texture="banana_tex" />

    	<material name="hammer_head_mat" rgba="0.7 0.7 0.7 1" specular="0.5" />
		<material name="hammer_neck_mat" rgba="0.73 0.5 0.39 1" specular="0.5" />

		<material name="knife_blade_mat" rgba="0.75 0.75 0.75 1" specular="0.5" />
		<material name="knife_handle_mat" rgba="0.1 0.1 0.1 1" />

		<material name="duck_mat" rgba="1 1 0 1.0" />
        <texture name="basket_tex" type="2d" file="../libero_basket/texture.png" />
        <material name="basket_mat" texture="basket_tex" />

		
		
    </asset>

    <worldbody>
        
		<light pos="1.3 0.7 2.5" dir="0 0 -1" directional="true" />
		<geom name="floor" size="0 0 0.05" type="plane" material="groundplane" />
		<geom name="x-aixs" group="2" type="cylinder" contype="0" conaffinity="0" fromto="0 0 0 1 0 0" size="0.01" rgba="1 0 0 1" />
		<geom name="y-aixs" group="2" type="cylinder" contype="0" conaffinity="0" fromto="0 0 0 0 1 0" size="0.01" rgba="0 1 0 1" />
		<geom name="z-aixs" group="2" type="cylinder" contype="0" conaffinity="0" fromto="0 0 0 0 0 1" size="0.01" rgba="0 0 1 1" />

		
		<camera name="cam" pos="0.85 0.8 1.6" xyaxes="0 -1 0 1 0 0.5" mode="fixed" />

		<body name="mocap" mocap="true" pos="0.8 0.6 0.74">
			<geom name="mocap" type="sphere" size="0.000001" />
		</body>

		<body name="Apple" pos="1.3 0.6 0.9" quat="0.7071 0.7071 0 0">
			<joint name="Apple_joint" type="free" damping="0.1" />
			<geom name="Apple" type="mesh" mesh="Apple" material="apple_mat" />
		</body>

		<body name="Banana" pos="1.25 0.7 0.9" quat="0 1 0 0">
			<joint name="Banana_joint" type="free" damping="0.1" />
			<geom name="Banana" type="mesh" mesh="Banana" material="banana_mat" />
		</body>

		

		

		<body name="Hammer" pos="1.3 0.8 0.9" quat="0 0 1 0">
    		<joint name="Hammer_joint" type="free" damping="0.1" />
    		<geom name="hammer_head_visual" type="mesh" mesh="hammer_head" material="hammer_head_mat" group="1" />
    		<geom name="hammer_neck_visual" type="mesh" mesh="hammer_neck" material="hammer_neck_mat" group="1" />
    		<geom name="hammer_contact0" type="mesh" mesh="hammer_contact0" condim="4" rgba="0 0 0 0" contype="1" conaffinity="1" group="0" />
    		<geom name="hammer_contact1" type="mesh" mesh="hammer_contact1" condim="4" rgba="0 0 0 0" contype="1" conaffinity="1" group="0" />
		</body>

		<body name="Knife" pos="1.45 0.8 0.9" euler="0 0 0">
    		<joint name="Knife_joint" type="free" damping="0.1" />
    		<geom name="knife_blade_visual" type="mesh" mesh="knife_blade" material="knife_blade_mat" group="1" />
    		<geom name="knife_handle_visual" type="mesh" mesh="knife_handle" material="knife_handle_mat" group="1" />
    		<geom name="knife_contact0" type="mesh" mesh="knife_contact0" condim="4" rgba="0 0 0 0" contype="1" conaffinity="1" group="0" />
    		<geom name="knife_contact1" type="mesh" mesh="knife_contact1" condim="4" rgba="0 0 0 0" contype="1" conaffinity="1" group="0" />
		</body>

		<body name="Duck" pos="1.3 1.0 0.9" euler="0 0 2.2">
    		<joint name="Duck_joint" type="free" damping="0.1" />
    		<geom name="duck_visual" type="mesh" mesh="duck" material="duck_mat" group="1" />
    		<geom name="duck_contact0" type="mesh" mesh="duck_contact0" condim="4" rgba="0 0 0 0" contype="1" conaffinity="1" group="0" />
    		<geom name="duck_contact1" type="mesh" mesh="duck_contact1" condim="4" rgba="0 0 0 0" contype="1" conaffinity="1" group="0" />
    		<geom name="duck_contact2" type="mesh" mesh="duck_contact2" condim="4" rgba="0 0 0 0" contype="1" conaffinity="1" group="0" />
		</body>

		<body name="Basket" pos="1.02 0.26 0.80" euler="0 0 0">
			<geom name="basket_visual" type="mesh" mesh="basket_mesh" material="basket_mat" group="1" />
			<site type="box" pos="0 0 0.036" quat="1 0 0 0" size="0.062 0.062 0.028" group="0" rgba="0.8 0 0 0" name="basket_contain_region" />
			<geom name="basket_bottom" solimp="0.998 0.998 0.001" solref="0.001 1" density="100" friction="0.95 0.3 0.1" type="box" pos="0 0 0.003" quat="1 0 0 0" rgba="0.2 0.9 0.2 0.22" condim="4" group="0" size="0.067 0.067 0.003" />
			<geom name="basket_wall_xn" solimp="0.998 0.998 0.001" solref="0.001 1" density="100" friction="0.95 0.3 0.1" type="box" pos="-0.067 0 0.030" quat="1 0 0 0" rgba="0.2 0.9 0.2 0.22" condim="4" group="0" size="0.0035 0.067 0.030" />
			<geom name="basket_wall_xp" solimp="0.998 0.998 0.001" solref="0.001 1" density="100" friction="0.95 0.3 0.1" type="box" pos="0.067 0 0.030" quat="1 0 0 0" rgba="0.2 0.9 0.2 0.22" condim="4" group="0" size="0.0035 0.067 0.030" />
			<geom name="basket_wall_yn" solimp="0.998 0.998 0.001" solref="0.001 1" density="100" friction="0.95 0.3 0.1" type="box" pos="0 -0.067 0.030" quat="1 0 0 0" rgba="0.2 0.9 0.2 0.22" condim="4" group="0" size="0.067 0.0035 0.030" />
			<geom name="basket_wall_yp" solimp="0.998 0.998 0.001" solref="0.001 1" density="100" friction="0.95 0.3 0.1" type="box" pos="0 0.067 0.030" quat="1 0 0 0" rgba="0.2 0.9 0.2 0.22" condim="4" group="0" size="0.067 0.0035 0.030" />
		</body>

		

		
		<body name="zone_pickup" pos="1.4 0.6 0.73" quat="1 0 0 0">
			<geom name="zone_pickup" type="box" size="0.2 0.6 0.01" rgba="0 1 0 0.1" contype="0" conaffinity="0" />
		</body>
		<body name="zone_drop" pos="0.2 0.2 0.73" quat="1 0 0 0">
			<geom name="zone_drop" type="box" size="0.2 0.2 0.01" rgba="1 0 0 0.1" contype="0" conaffinity="0" />
		</body>

        
		<body name="table1" euler="0 0 0" pos="0.8 0 0.74">
		  <geom name="table1" type="mesh" mesh="table" group="2" rgba="0.35 0.35 0.35 1" mass="0" contype="0" conaffinity="0" />
		</body>
		<body name="table2" euler="0 0 0" pos="1.6 0 0.74">
		  <geom name="table2" type="mesh" mesh="table" group="2" rgba="0.35 0.35 0.35 1" mass="0" contype="0" conaffinity="0" />
		</body>

		<body name="simple_table" pos="0.8 0.6 0.69" quat="1 0 0 0">
			<geom name="simple_table" type="box" size="0.8 0.6 0.05" rgba="0.5 0.5 0.5 0.1" />
		</body>
    </worldbody>

    <contact>
		<exclude body1="flange" body2="2f85_base" />
		<exclude body1="wrist_3_link" body2="2f85_base" />
		<exclude body1="wrist_2_link" body2="2f85_base" />
	</contact>

	<equality>
		<weld name="attach" body1="flange" body2="2f85_base" active="false" />
		<weld name="attach_mocap" body1="mocap" body2="ur5e_base" active="false" />
	</equality>

</mujoco>